{
  "name": "cool95",
  "version": "1.0.0",
  "description": "cool95 Desktop Experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "pack": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "cool.timur.cool95",
    "productName": "Cool 95",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": "dmg"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
