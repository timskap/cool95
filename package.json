{
  "name": "cool95",
  "version": "1.0.0",
  "description": "cool95 Desktop Experience",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --mac --win",
    "pack": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "cool.timur.cool95",
    "productName": "Cool 95",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "app/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
